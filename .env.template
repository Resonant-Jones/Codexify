# .env.template
# Environment configuration template for Guardian backend

OPENAI_API_KEY=your-openai-key-here
GROQ_API_KEY=your-groq-key-here
DEBUG=true
LOG_LEVEL=INFO
ENV=development
# Optional additions if your system evolves
# .env  (or .env.local if you prefer)
DATABASE_URL=postgresql://guardian:guardian@127.0.0.1:5433/guardian
GUARDIAN_DB_URL=${DATABASE_URL}
GUARDIAN_DB_PATH=__DISABLE_SQLITE__    # <- guards against accidental jones@resonantconstructs.ai
CACHE_ENABLED=false
PORT=8000