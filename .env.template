# .env.template / .env.example
# Local-only environment configuration. Copy to .env and edit.
# Never commit your real .env. Templates are the source of truth.
#
# Security hygiene:
# - .env is ignored via .gitignore: keep it local-only.
# - Rotate GUARDIAN_API_KEY regularly; prefer short-lived tokens.
# - Never ship VITE_GUARDIAN_API_KEY in any hosted/public build.

# --- Core runtime ---
ENV=development
LOG_LEVEL=INFO
DEBUG=false
PORT=8000

# --- Auth boundary ---
# local  -> static X-API-Key auth is allowed (localhost/dev only)
# remote -> static API keys are rejected; session/JWT is required
GUARDIAN_AUTH_MODE=local
# Backend auth secret. Use a long random value and rotate frequently.
GUARDIAN_API_KEY=dev-local-only-change-me
# Local-only browser key injection. Mirror the backend key ONLY when running
# on localhost/trusted dev builds; leave empty for anything public or hosted.
# Example: VITE_GUARDIAN_API_KEY=${GUARDIAN_API_KEY}
VITE_GUARDIAN_API_KEY=
# Session/JWT signing secret (required when GUARDIAN_AUTH_MODE=remote)
GUARDIAN_SESSION_SECRET=replace-with-long-random-secret
GUARDIAN_JWT_SECRET=
GUARDIAN_DEV_MODE=false

# --- Database ---
DATABASE_URL=postgresql://codexify_user:codexify@localhost:5432/codexify
GUARDIAN_DATABASE_URL=${DATABASE_URL}
GUARDIAN_DB_URL=${DATABASE_URL}
GUARDIAN_DB_PATH=__DISABLE_SQLITE__

# --- Docker Compose overrides (optional) ---
POSTGRES_USER=codexify
POSTGRES_PASSWORD=replace-with-postgres-password
POSTGRES_DB=Codexify

# --- Local LLM (Ollama/OpenAI-compatible) ---
# NOTE: LLM_PROVIDER must be a single provider id (not a comma-separated list).
LLM_PROVIDER=local
ALLOW_CLOUD_PROVIDERS=false
LLM_MODEL=library2/ministral-3:8b
LOCAL_BASE_URL=http://localhost:11434/v1
LOCAL_API_KEY=local
LOCAL_LLM_MODEL=library2/ministral-3:8b
VAULTNODE_BASE_URL=

# --- Embeddings ---
EMBEDDER_PROVIDER=local
EMBEDDING_BACKEND=dummy
EMBEDDING_DIM=128
EMBEDDING_MODEL=
LOCAL_EMBED_MODEL=/models/bge-large-en-v1.5

# --- Cloud providers (optional; set ALLOW_CLOUD_PROVIDERS=true) ---
# Also set CODEXIFY_LOCAL_ONLY_MODE=false and include the target provider in
# CODEXIFY_EGRESS_ALLOWLIST (for example: openai,groq,minimax).
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_EMBED_MODEL=
OPENAI_EMBEDDING_MODEL=
GROQ_API_KEY=
GROQ_BASE_URL=
MINIMAX_API_KEY=
MINIMAX_API_BASE=
MINIMAX_MODEL=
MINIMAX_TIMEOUT_SECONDS=60
ANTHROPIC_API_KEY=
GENAI_API_KEY=

# --- Neo4j ---
NEO4J_URL=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASS=replace-with-neo4j-password

# --- Integrations (optional) ---
NOTION_API_KEY=
DISCORD_BOT_TOKEN=
GITHUB_TOKEN=

# --- Workers / eventing ---
ENABLE_OUTBOX=true
ENABLE_CONNECTOR_WORKER=false

# --- Cache ---
CACHE_ENABLED=false

# --- Security / rate limiting (optional) ---
GUARDIAN_ENABLE_RATE_LIMITING=1
GUARDIAN_RATE_LIMITS=100/minute,1000/hour
GUARDIAN_ENABLE_SECURITY_HEADERS=1
GUARDIAN_CSP_POLICY=default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:;
