# .env.template
# Environment configuration template for Guardian backend

LLM_PROVIDER=groq
LLM_MODEL=gpt-4o-mini
EMBEDDER_PROVIDER=local
LOCAL_EMBEDDER_MODEL=all-MiniLM-L6-v2
OPENAI_API_KEY=your-openai-key-here
OPENAI_BASE_URL=
GROQ_API_KEY=your-groq-key-here
GROQ_BASE_URL=https://api.groq.com/openai/v1
ENABLE_OUTBOX=true
ENABLE_CONNECTOR_WORKER=false
GITHUB_TOKEN=
DEBUG=true
LOG_LEVEL=INFO
ENV=development
# Optional additions if your system evolves
# .env  (or .env.local if you prefer)
DATABASE_URL=postgresql://guardian:guardian@db:5432/guardian
GUARDIAN_DB_URL=${DATABASE_URL}
GUARDIAN_DB_PATH=__DISABLE_SQLITE__    # <- guards against accidental jones@resonantconstructs.ai
CACHE_ENABLED=false
PORT=8000
# When containerizing, always keep the host portion set to `db` so the backend
# reaches the Postgres service on the Docker network. Only swap to localhost
# when running both backend and Postgres directly on your machine (no containers).
BOLT_URL=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASS=guardian
