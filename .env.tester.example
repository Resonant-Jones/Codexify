# .env.tester.example
#
# Friends & family tester environment template.
# Copy this file to .env.tester and replace every placeholder with real values
# before starting the tester stack.
#
#   cp .env.tester.example .env.tester
#   # edit .env.tester
#
# .env.tester is git-ignored and must NEVER be committed.
# This file (.env.tester.example) contains no real secrets and is safe to commit.

# --- Compose project isolation ---
COMPOSE_PROJECT_NAME=codexify_tester

# --- Compose env file pointer (so services read this file) ---
CODEXIFY_RUNTIME_ENV_FILE=.env.tester

# --- Supported profile ---
CODEXIFY_SUPPORTED_PROFILE=v1-friends-family-web

# --- API key (required at backend startup) ---
# Generate a long random string, e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
GUARDIAN_API_KEY=<generate-a-real-secret>

# --- Session and JWT secrets (required for auth) ---
# Generate fresh secrets, e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
GUARDIAN_SESSION_SECRET=<generate-a-real-secret>
GUARDIAN_JWT_SECRET=<generate-a-real-secret>

# --- CORS allowlist ---
# Must include the tester frontend origin(s).
GUARDIAN_ALLOWED_ORIGINS=http://localhost:5174,http://127.0.0.1:5174

# --- Frontend -> backend base URL ---
# Tells the Vite dev server where the tester backend lives.
VITE_GUARDIAN_API_BASE=http://localhost:8889

# --- Postgres credentials (must match docker-compose defaults or be overridden) ---
POSTGRES_USER=codexify
POSTGRES_PASSWORD=codexify
POSTGRES_DB=Codexify

# --- Neo4j credentials ---
NEO4J_USER=neo4j
NEO4J_PASS=codexify

# --- Local LLM ---
# Uncomment and adjust if your Whoosh'd/Ollama endpoint differs.
# LOCAL_BASE_URL=http://host.docker.internal:8000/v1
# LOCAL_CHAT_MODEL=mlx-community/gemma-4-e2b-it-4bit
