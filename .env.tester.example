# .env.tester.example
#
# Friends & family tester environment template.
# Copy this file to .env.tester and replace every placeholder with real values
# before starting the tester stack.
#
#   cp .env.tester.example .env.tester
#   # edit .env.tester
#
# .env.tester is git-ignored and must NEVER be committed.
# This file (.env.tester.example) contains no real secrets and is safe to commit.

# --- Compose project isolation ---
COMPOSE_PROJECT_NAME=codexify_tester

# --- Compose env file pointer (so services read this file) ---
CODEXIFY_RUNTIME_ENV_FILE=.env.tester

# --- Supported profile ---
CODEXIFY_SUPPORTED_PROFILE=v1-friends-family-web

# --- API key (required at backend startup) ---
# Generate a long random string, e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
GUARDIAN_API_KEY=<generate-a-real-secret>

# --- Session and JWT secrets (required for auth) ---
# Generate fresh secrets, e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
GUARDIAN_SESSION_SECRET=<generate-a-real-secret>
GUARDIAN_JWT_SECRET=<generate-a-real-secret>

# --- CORS allowlist ---
# The tester UI uses Vite's same-origin proxy. Keep this to operator-loopback
# origins unless you intentionally add another browser-access path.
GUARDIAN_ALLOWED_ORIGINS=http://localhost:5174,http://127.0.0.1:5174

# --- Dedicated Tailscale tester identity ---
# Create a reusable, non-ephemeral, pre-approved auth key tagged
# `tag:codexify-test`; never paste it into a tracked file or shell history.
TAILSCALE_TEST_AUTHKEY=<tskey-auth-tagged-codexify-test>
TAILSCALE_TEST_HOSTNAME=codexify-test
# The exact MagicDNS FQDN shown for the node in the Tailscale admin console.
# This lets Vite accept only this Host header, not every *.ts.net hostname.
TAILSCALE_TEST_FQDN=codexify-test.<your-tailnet>.ts.net
# Optional: pin a specific upstream image tag or digest after validation.
# TAILSCALE_TEST_IMAGE=tailscale/tailscale:<validated-version-or-digest>
# Operator-only local fallback; this binds to 127.0.0.1, never all interfaces.
CODEXIFY_TESTER_LOCAL_PORT=5174

# --- Postgres credentials (must match docker-compose defaults or be overridden) ---
POSTGRES_USER=codexify
POSTGRES_PASSWORD=codexify
POSTGRES_DB=Codexify

# --- Neo4j credentials ---
NEO4J_USER=neo4j
NEO4J_PASS=codexify

# --- Local LLM ---
# The friends/family profile routes chat through DeepSeek and exposes only
# this configured model. Keep the API key in this ignored file.
LLM_PROVIDER=deepseek
ALLOW_CLOUD_PROVIDERS=true
CODEXIFY_LOCAL_ONLY_MODE=false
CODEXIFY_EGRESS_ALLOWLIST=deepseek
DEEPSEEK_API_KEY=<generate-a-real-deepseek-key>
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_CHAT_MODEL=deepseek-v4-flash
