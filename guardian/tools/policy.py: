# guardian/tools/policy.py
from __future__ import annotations

import os
from typing import Optional, Dict, Any
import logging
from fastapi import HTTPException, Request, status

from guardian.tools.spec import ToolSpec

logger = logging.getLogger(__name__)

POLICY_MODE_ENV = "CODEXIFY_POLICY_MODE"  # enforce | warn | off

SINGLE_USER_ID_ENV = "CODEXIFY_SINGLE_USER_ID"
REQUEST_ID_HEADER = "X-Request-Id"

def get_policy_mode() -> str:
    mode = (os.getenv(POLICY_MODE_ENV) or "enforce").strip().lower()
    if mode not in {"enforce", "warn", "off"}:
        # Fail closed by default if misconfigured.
        mode = "enforce"
    return mode

def _handle_violation(*, mode: str, status_code: int, detail: Dict[str, Any], request: Optional[Request] = None, tool: Optional[ToolSpec] = None) -> None:
    """Centralized violation handling.

    - enforce: raise HTTPException
    - warn: log and continue
    - off: continue (but still log at debug)

    We always enrich the event with request + tool context when available.
    """
    enriched: Dict[str, Any] = dict(detail)
    enriched.setdefault("policy_mode", mode)

    if tool is not None:
        # ToolSpec is expected to have stable identity fields; fall back safely.
        tool_id = getattr(tool, "tool_id", None) or getattr(tool, "operation_id", None) or getattr(tool, "command_id", None)
        if tool_id:
            enriched.setdefault("tool_id", tool_id)

    if request is not None:
        rid = request.headers.get(REQUEST_ID_HEADER)
        if rid:
            enriched.setdefault("request_id", rid)

    if mode == "enforce":
        raise HTTPException(status_code=status_code, detail=enriched)
    if mode == "warn":
        logger.warning("tool_policy_violation: %s", enriched)
        return

    # mode == "off": allow, but leave an audit breadcrumb at debug level.
    logger.debug("tool_policy_skipped: %s", enriched)

def require_env(var: str) -> str:
    v = os.getenv(var)
    if not v:
        raise HTTPException(
            status_code=status.HTTP_500_INTERNAL_SERVER_ERROR,
            detail={"error": "misconfigured_runtime", "missing_env": var},
        )
    return v

def resolve_user_id(request: Request) -> Optional[str]:
    """Resolve the effective user id.

    Precedence:
    1) Explicit request header X-User-Id
    2) Single-user deployment fallback via CODEXIFY_SINGLE_USER_ID

    Returns None if neither is present.
    """
    return request.headers.get("X-User-Id") or os.getenv(SINGLE_USER_ID_ENV) or None

def enforce_tool_policy(request: Request, tool: ToolSpec, *, mode: Optional[str] = None) -> None:
    """Enforce (or warn/skip) tool policy.

    Opinionated defaults:
    - Identity is infrastructure: required when ToolSpec demands it.
    - Docker-first loopback is required when ToolSpec demands it.

    The behavior is controlled by CODEXIFY_POLICY_MODE:
    - enforce (default): raise on violations
    - warn: log violations and continue
    - off: skip enforcement entirely
    """
    if mode is None:
        mode = get_policy_mode()

    # NOTE: even when mode == "off" we still run checks so we can emit a debug-level
    # audit breadcrumb via _handle_violation(...). _handle_violation is responsible for
    # deciding whether to raise (enforce), warn (warn), or allow (off).

    # 1) Identity
    if tool.policy.require_identity:
        if not resolve_user_id(request):
            _handle_violation(
                mode=mode,
                status_code=status.HTTP_401_UNAUTHORIZED,
                detail={"error": "missing_identity_context"},
                request=request,
                tool=tool,
            )

    # 2) Loopback requirement (your Docker-only opinionated posture)
    if tool.policy.require_loopback:
        try:
            require_env("GUARDIAN_COMMAND_BUS_LOOPBACK_BASE")
        except HTTPException as e:
            _handle_violation(
                mode=mode,
                status_code=e.status_code,
                detail=e.detail if isinstance(e.detail, dict) else {"error": "misconfigured_runtime"},
                request=request,
                tool=tool,
            )

    # 3) Side-effects gating (Phase 2-ready hook)
    # For now, enforce role visibility tiers later.
    if tool.policy.visibility in ("admin", "internal"):
        # TODO: wire real authz claims/roles.
        _handle_violation(
            mode=mode,
            status_code=status.HTTP_403_FORBIDDEN,
            detail={"error": "forbidden_tool", "visibility": tool.policy.visibility},
            request=request,
            tool=tool,
        )

    # 4) Network egress gating
    if tool.policy.network_egress:
        # Example enforcement: ensure allowlist configured
        allowlist = (os.getenv("CODEXIFY_EGRESS_ALLOWLIST", "") or "").strip()
        if not allowlist:
            _handle_violation(
                mode=mode,
                status_code=status.HTTP_500_INTERNAL_SERVER_ERROR,
                detail={"error": "egress_not_configured"},
                request=request,
                tool=tool,
            )
