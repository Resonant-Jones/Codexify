{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://resonantconstructs.ai/schemas/task_result.schema.json",
  "title": "Campaign Runner Task Result (Inference Output)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "status",
    "summary",
    "tests_ran",
    "notes"
  ],
  "properties": {
    "status": {
      "type": "string",
      "enum": [
        "success",
        "failed",
        "blocked"
      ]
    },
    "summary": {
      "type": "string"
    },
    "tests_ran": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "notes": {
      "type": "string"
    }
  }
}
