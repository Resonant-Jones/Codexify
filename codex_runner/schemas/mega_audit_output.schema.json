{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://resonantconstructs.ai/schemas/mega_audit_output.schema.json",
  "title": "Campaign Runner Mega Audit Output",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "audit_id",
    "repo",
    "generated_at",
    "agent",
    "reports",
    "runner_ready_findings",
    "campaign_derivation_rules",
    "derived_campaigns"
  ],
  "properties": {
    "audit_id": {
      "type": "string",
      "description": "Runner-owned deterministic audit identifier.",
      "pattern": "^AUDIT_[0-9a-f]{12}$"
    },
    "repo": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "branch",
        "commit"
      ],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "branch": {
          "type": "string",
          "minLength": 1
        },
        "commit": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 0
        }
      }
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "agent": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "model",
        "mode"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "model": {
          "type": "string",
          "minLength": 1
        },
        "mode": {
          "type": "string",
          "enum": [
            "audit"
          ]
        }
      }
    },
    "reports": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "report_id",
          "type",
          "path",
          "severity_summary",
          "focus"
        ],
        "properties": {
          "report_id": {
            "type": "string",
            "minLength": 1
          },
          "type": {
            "type": "string",
            "minLength": 1
          },
          "path": {
            "type": "string",
            "minLength": 1
          },
          "severity_summary": {
            "type": [
              "object",
              "null"
            ],
            "additionalProperties": false,
            "required": [
              "RISK",
              "WARN",
              "INFO"
            ],
            "properties": {
              "RISK": {
                "type": "integer",
                "minimum": 0
              },
              "WARN": {
                "type": "integer",
                "minimum": 0
              },
              "INFO": {
                "type": "integer",
                "minimum": 0
              }
            }
          },
          "focus": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      }
    },
    "runner_ready_findings": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "finding_id",
          "area",
          "severity",
          "title",
          "description",
          "evidence",
          "relates_to_core_loop",
          "suggested_task_outcome",
          "suggested_commands",
          "dependencies",
          "notes"
        ],
        "properties": {
          "finding_id": {
            "type": "string",
            "pattern": "^FINDING-\\d{4}-\\d{2}-\\d{2}-\\d{3}$"
          },
          "area": {
            "type": "string",
            "enum": [
              "security",
              "core-loop",
              "dx",
              "performance",
              "testing",
              "docs-drift",
              "other"
            ]
          },
          "severity": {
            "type": "string",
            "enum": [
              "RISK",
              "WARN",
              "INFO"
            ]
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "evidence": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "file",
                "lines"
              ],
              "properties": {
                "file": {
                  "type": "string",
                  "minLength": 1
                },
                "lines": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          },
          "relates_to_core_loop": {
            "type": "string",
            "enum": [
              "rag",
              "migration",
              "doc-upload",
              "image-gallery",
              "image-gen",
              "doc-gen",
              "none"
            ]
          },
          "suggested_task_outcome": {
            "type": "string",
            "minLength": 1
          },
          "suggested_commands": {
            "type": "array",
            "minItems": 0,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "dependencies": {
            "type": "array",
            "minItems": 0,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "campaign_derivation_rules": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "strategy",
        "group_by",
        "priority_order"
      ],
      "properties": {
        "strategy": {
          "type": "string",
          "minLength": 1
        },
        "group_by": {
          "type": "array",
          "minItems": 0,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "priority_order": {
          "type": "array",
          "minItems": 0,
          "items": {
            "type": "string",
            "enum": [
              "RISK",
              "WARN",
              "INFO"
            ]
          }
        }
      }
    },
    "derived_campaigns": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "campaign_id",
          "campaign_type",
          "source_findings"
        ],
        "properties": {
          "campaign_id": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}::[a-z0-9_]+::\\d{3}$"
          },
          "campaign_type": {
            "type": "string",
            "enum": [
              "security",
              "mvp",
              "followup"
            ]
          },
          "source_findings": {
            "type": "array",
            "minItems": 0,
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    }
  }
}
