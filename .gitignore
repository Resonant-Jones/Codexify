# This file silences the parts of the system that do not carry meaning.

# --- Python ---
__pycache__/
*.py[cod]
*$py.class

# Virtual environment
venv/

# Env files (ignore all env files except templates/examples)
.env
.env.*
!.env.example
!.env.template

# Logs
*.log
logs/

# Unit test / coverage reports
htmlcov/
.coverage
.tox/
.nox/
.cache/
.pytest_cache/
.mypy_cache/

# IDEs and editors
.vscode/
.idea/
*.sublime-workspace
*.code-workspace

# OS files
.DS_Store
.AppleDouble
.LSOverride

# --- Databases / local runtime ---
*.sqlite3
*.db
*.bak
:memory:

# Guardian DB (local)
guardian/guardian.db
guardian/guardian.*.db

# --- Node / frontend build artifacts ---
node_modules/
.pnpm-store/
.vite/
dist/
build/

# TypeScript build info caches
frontend/src/node_modules/.tmp/
frontend/src/tsconfig.tsbuildinfo
*.egg-info/

# Frontend debug/test artifacts (local-only)
frontend/src/playwright-report/
frontend/src/playwright-report/**
frontend/src/screenshots/guardian-chat__*.png
frontend/src/screenshots/guardian-chat-panel__*.png
frontend/src/screenshots/guardian-chat*.png
frontend/src/screenshots/guardian-chat-panel*.png
frontend/src/screenshots/layout/
frontend/src/screenshots/layout/**

# --- Artifacts / tooling ---
artifacts/
tmp-clone/
__DISABLE_SQLITE__

# Sourcegraph local deployment
/dev_tools/deploy-sourcegraph-docker/

# Embedded repos; do not track
/groq-code-cli/

# Codemap snapshots
/guardian/codemap/*.json

# Personal chat history exports
/chatgpt_migrations/conversations.json
/chatgpt_conversation.json

# Misc local folders
HRM/
frontend/store/

# Vector DB caches
.chroma/
.chroma_test/

# Models (large/local)
models/

# Local runtime / secrets (DO NOT COMMIT)
/data/credentials.json
/data/token.pickle
/data/trust_registry.json
