# This file silences the parts of the system that do not carry meaning.

# --- Python ---
__pycache__/
*.py[cod]
*$py.class

# Virtual environment
venv/

# Env files (ignore all env files except templates/examples)
.env
.env.*
!.env.example
!.env.template

# Logs
*.log
logs/

# Unit test / coverage reports
htmlcov/
.coverage
.tox/
.nox/
.cache/
.pytest_cache/
.mypy_cache/

# IDEs and editors
.vscode/
.idea/
*.sublime-workspace
*.code-workspace

# OS files
.DS_Store
.AppleDouble
.LSOverride

# --- Databases / local runtime ---
*.sqlite3
*.db
*.bak
:memory:

# Guardian DB (local)
guardian/guardian.db
guardian/guardian.*.db

# --- Node / frontend build artifacts ---
node_modules/
.pnpm-store/
.vite/
dist/
build/

# Lockfiles: keep only the intentional roots
# (Root workspace lockfile is tracked; nested lockfiles are never tracked.)
**/src/pnpm-lock.yaml

# TypeScript build info caches
*.tsbuildinfo
frontend/src/node_modules/.tmp/

# Frontend debug/test artifacts (local-only)
frontend/src/playwright-report/
frontend/src/test-results/
frontend/src/screenshots/
frontend/src/screenshots/**
frontend/src/traces/
frontend/src/**/.last-run.json
.last-run.json

# --- Artifacts / tooling ---
artifacts/
tmp-clone/
__DISABLE_SQLITE__

# Sourcegraph local deployment
/dev_tools/deploy-sourcegraph-docker/

# Embedded repos; do not track
/groq-code-cli/

# Codemap snapshots
/guardian/codemap/*.json

# Personal chat history exports
/chatgpt_migrations/conversations.json
/chatgpt_conversation.json

# Misc local folders
HRM/
frontend/store/

# Vector DB caches
.chroma/
.chroma_test/

# Models (large/local)
models/

# Local runtime / secrets (DO NOT COMMIT)
/data/credentials.json
/data/token.pickle
/data/trust_registry.json
/guardian/secrets/
/guardian/secrets/*.json
**/token.json
**/client_secret*.json

# Gitleaks configuration (tracked)
# (We want the config committed so pre-commit can run gitleaks deterministically.)

# Gitleaks scan outputs (local-only)
.gitleaks/
gitleaks-report.json
gitleaks-report.sarif
gitleaks-report.txt
gitleaks-report.*

# Local audit outputs
/docs/_audit_runs/

# local reports
/docs/reports/

# Local temp artifacts
/guardian/temp/
/guardian/temp/*.json

# ChatGPT export artifacts
/data/conversation.json
/docs/conversation.json

# --- Hugging Face / Transformers caches (TTS + embeddings) ---
# We mount these via Docker volume in prod/dev; keep any local copies out of git.
.hf_cache/
hf_cache/
.huggingface/
.huggingface-cache/
.cache/huggingface/
**/.cache/huggingface/

# HF Hub snapshot layout (when cached inside a repo-mounted path)
**/models--*--*/
**/datasets--*--*/
**/spaces--*--*/

# Transformers / Torch caches (occasionally used depending on libs)
.cache/torch/
**/.cache/torch/
.cache/transformers/
**/.cache/transformers/

# Local artifacts
boxbeyond-kutiraai/
output/
tmp/
**/output/
**/tmp/
data/
chatgpt-conversation-extractor-master/
chatgpt-conversation.json

# local agent/tooling
.claude/
.codex/

# Local/vendor checkouts
MiniMax-MCP-main/
boxbeyond-kutiraai

# Local exports / data dumps
conversations.json

# Vendor repos (kept outside repo)
boxbeyond-kutiraai/
