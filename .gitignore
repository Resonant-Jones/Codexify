# This file silences the parts of the system that do not carry meaning.
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Virtual environment
# Ignore all env files except .env.example (for secrets safety)
venv/
.env
.env.*
!.env.example

# Logs
*.log

# Unit test / coverage reports
htmlcov/
.coverage
.tox/
.nox/
.cache/

# IDEs and editors
.vscode/
.idea/

# OS files
.DS_Store

# Database / temp files
*.sqlite3
*.db
*.bak
