# This file silences the parts of the system that do not carry meaning.
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Virtual environment
# Ignore all env files except .env.example (for secrets safety)
venv/
.env
.env.*
!.env.example
!.env.template

# Logs
*.log
logs/

# Unit test / coverage reports
htmlcov/
.coverage
.tox/
.nox/
.cache/
.pytest_cache/
.mypy_cache/

# IDEs and editors
.vscode/
.idea/
*.sublime-workspace
*.code-workspace

# OS files
.DS_Store
.AppleDouble
.LSOverride

# Database / temp files
*.sqlite3
*.db
*.bak
guardian-token.md
node_modules
build/
dist/

# TypeScript build info caches
frontend/src/node_modules/.tmp/
frontend/src/tsconfig.tsbuildinfo
*.egg-info/

# Sourcegraph local deployment
# Sourcegraph local deployment
dev_tools/deploy-sourcegraph-docker/
# codemap snapshots
guardian/codemap/codemap.json
artifacts/

# embedded repos we do NOT track
dev_tools/deploy-sourcegraph-docker/
groq-code-cli/

# build junk
guardian.egg-info/
guardian_codex.egg-info/
artifacts/
guardian/codemap/*.json

# embedded repos; do not track
dev_tools/deploy-sourcegraph-docker/
groq-code-cli/

# build junk
guardian.egg-info/
guardian_codex.egg-info/
artifacts/
guardian/codemap/*.json
dev_tools/deploy-sourcegraph-docker/
groq-code-cli/

# Vite output & caches
.vite/
node_modules/.vite/
dist/

# --- allow Vitest files in src ---
!src/**/__tests__/
!src/**/__tests__/**
!src/**/*.test.ts
!src/**/*.test.tsx
!src/vitest.config.ts
!src/test/
!src/test/**/*
guardian/guardian.db
guardian/guardian.*.db
.env.local
.env
guardian/codemap/codemap.json
models/moondream1/*.safetensors
models/**.safetensors
__DISABLE_SQLITE__
makefile
tmp-clone/

# Personal chat history exports
chatgpt_migrations/conversations.json
.pnpm-store/
HRM/
.env
frontend/store
.env
