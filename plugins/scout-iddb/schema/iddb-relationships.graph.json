{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "Scout IDDB Relationship Definitions",
  "description": "Descriptive schema for Scout log relationships in IDDB. These are not active registrations.",
  "version": "0.1.0",
  "state": "dormant",
  "relationshipTypes": [
    {
      "type": "OBSERVED_AT",
      "description": "Links a Scout log to the URL it observed or interacted with",
      "state": "pending",
      "source": {
        "nodeType": "ScoutLog",
        "description": "The log entry containing URL observation"
      },
      "target": {
        "nodeType": "URL",
        "description": "The URL that was observed"
      },
      "properties": {
        "observedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp of observation",
          "required": true
        },
        "method": {
          "type": "string",
          "enum": ["GET", "POST", "PUT", "PATCH", "DELETE", "HEAD", "OPTIONS", "CONNECT", "TRACE", "OTHER"],
          "description": "HTTP method if applicable",
          "required": false
        },
        "statusCode": {
          "type": "integer",
          "description": "HTTP status code if applicable",
          "required": false
        },
        "responseTime": {
          "type": "number",
          "description": "Response time in milliseconds",
          "required": false
        },
        "context": {
          "type": "string",
          "description": "Additional context about the observation",
          "required": false
        }
      },
      "cardinality": "many-to-one",
      "notes": [
        "Multiple logs can observe the same URL",
        "Each observation captures temporal and contextual data"
      ]
    },
    {
      "type": "DESCRIBES",
      "description": "Links a Scout log to the component it describes or relates to",
      "state": "pending",
      "source": {
        "nodeType": "ScoutLog",
        "description": "The log entry describing component behavior"
      },
      "target": {
        "nodeType": "Component",
        "description": "The component being described"
      },
      "properties": {
        "relevance": {
          "type": "string",
          "enum": ["high", "medium", "low"],
          "description": "How relevant this log is to the component",
          "required": false
        },
        "category": {
          "type": "string",
          "enum": ["performance", "error", "lifecycle", "behavior", "security", "other"],
          "description": "Category of description",
          "required": false
        },
        "inferredBy": {
          "type": "string",
          "enum": ["explicit", "pattern", "curator", "manual"],
          "description": "How this relationship was determined",
          "required": false,
          "default": "explicit"
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Confidence score for inferred relationships (0-1)",
          "required": false
        }
      },
      "cardinality": "many-to-one",
      "notes": [
        "Logs can describe multiple components (use multiple relationships)",
        "Components accumulate knowledge from many log entries"
      ]
    },
    {
      "type": "GENERATED_BY",
      "description": "Links a Scout log to the runtime instance that generated it",
      "state": "pending",
      "source": {
        "nodeType": "ScoutLog",
        "description": "The log entry that was generated"
      },
      "target": {
        "nodeType": "RuntimeInstance",
        "description": "The runtime instance that generated the log"
      },
      "properties": {
        "generatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp when log was generated",
          "required": true
        },
        "processId": {
          "type": "string",
          "description": "Process or thread identifier within the runtime",
          "required": false
        },
        "sessionId": {
          "type": "string",
          "description": "Session identifier if applicable",
          "required": false
        },
        "sourceFile": {
          "type": "string",
          "description": "Source code file that generated the log",
          "required": false
        },
        "sourceLine": {
          "type": "integer",
          "description": "Line number in source file",
          "required": false
        }
      },
      "cardinality": "many-to-one",
      "notes": [
        "Each log is generated by exactly one runtime instance",
        "Runtime instances generate many logs over their lifecycle"
      ]
    },
    {
      "type": "RELATED_TO",
      "description": "Generic relationship between Scout logs for correlation",
      "state": "pending",
      "source": {
        "nodeType": "ScoutLog",
        "description": "The source log entry"
      },
      "target": {
        "nodeType": "ScoutLog",
        "description": "The related log entry"
      },
      "properties": {
        "relationType": {
          "type": "string",
          "enum": ["temporal", "causal", "trace", "session", "user", "error-chain", "other"],
          "description": "Type of relationship",
          "required": true
        },
        "strength": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Relationship strength (0-1)",
          "required": false
        },
        "direction": {
          "type": "string",
          "enum": ["before", "after", "concurrent", "causes", "caused-by"],
          "description": "Directional nature of relationship",
          "required": false
        },
        "inferredBy": {
          "type": "string",
          "enum": ["trace-id", "session-id", "timestamp", "curator", "manual"],
          "description": "How this relationship was determined",
          "required": false
        }
      },
      "cardinality": "many-to-many",
      "notes": [
        "Enables log correlation and event chain reconstruction",
        "Can be used for distributed tracing visualization"
      ]
    },
    {
      "type": "COMPONENT_USES",
      "description": "Links a component to another component it depends on or uses",
      "state": "pending",
      "source": {
        "nodeType": "Component",
        "description": "The component that uses another"
      },
      "target": {
        "nodeType": "Component",
        "description": "The component being used"
      },
      "properties": {
        "usageType": {
          "type": "string",
          "enum": ["imports", "calls", "depends-on", "publishes-to", "subscribes-to", "other"],
          "description": "Type of usage relationship",
          "required": false
        },
        "frequency": {
          "type": "string",
          "enum": ["high", "medium", "low", "unknown"],
          "description": "Frequency of usage",
          "required": false
        },
        "firstObserved": {
          "type": "string",
          "format": "date-time",
          "description": "When this relationship was first observed",
          "required": false
        },
        "lastObserved": {
          "type": "string",
          "format": "date-time",
          "description": "When this relationship was last observed",
          "required": false
        }
      },
      "cardinality": "many-to-many",
      "notes": [
        "Enables dependency graph construction from observability data",
        "Inferred from log patterns over time"
      ]
    }
  ],
  "notes": [
    "This schema is for documentation and type generation only.",
    "No automatic IDDB relationship creation occurs from this file.",
    "All relationships are marked with 'state: pending' until activation.",
    "Activate integration by connecting to IDDB relationship registry manually."
  ]
}
