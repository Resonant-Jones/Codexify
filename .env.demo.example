# Codexify Peekaboo demo credentials and local tester endpoints.
# Copy to .env.demo, replace DEMO_PASSWORD, and keep the real file local.
DEMO_API_BASE=http://localhost:8889
DEMO_FRONTEND_BASE=http://localhost:5174
DEMO_USERNAME=rowan
DEMO_PASSWORD=<choose-a-local-demo-password>

# Optional: the tester compose database is exposed on 5434.
# When omitted, the seed script derives this from .env.tester.
DEMO_DATABASE_URL=
