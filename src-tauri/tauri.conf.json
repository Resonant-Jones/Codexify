{
  "$schema": "https://schema.tauri.app/config/2.0.0-rc",
  "productName": "Codexify",
  "version": "0.1.0",
  "identifier": "com.codexify.desktop",
  "build": {
    "frontendDist": "../frontend/src/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm --dir frontend/src dev",
    "beforeBuildCommand": "pnpm --dir frontend/src build"
  },
  "app": {
    "windows": [
      {
        "title": "Codexify",
        "width": 1440,
        "height": 900,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
