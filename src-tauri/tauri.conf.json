{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Codexify",
  "version": "0.1.0",
  "identifier": "com.tauri.dev",
  "build": {
    "frontendDist": "../src/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "bash scripts/dev-frontend.sh",
    "beforeBuildCommand": "npm --prefix ../src run build"
  },
  "app": {
    "windows": [
      {
        "title": "Codexify",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self' http://localhost:5173; img-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-eval' 'unsafe-inline' http://localhost:5173; connect-src 'self' http://localhost:5173 http://127.0.0.1:8888 ws://localhost:5173 ws://127.0.0.1:5173"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
