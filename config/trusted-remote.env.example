# Trusted remote proof overlay example
# Copy to config/trusted-remote.env for local/dev use only.
# Never commit config/trusted-remote.env.

GUARDIAN_AUTH_MODE=remote
GUARDIAN_EXPOSURE_MODE=local_safe
CODEXIFY_ENABLE_TRUSTED_REMOTE_ROUTE_SURFACE=true

GUARDIAN_SESSION_SECRET=replace-with-local-dev-secret
GUARDIAN_JWT_SECRET=replace-with-local-dev-secret

GUARDIAN_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

CODEXIFY_LOCAL_ONLY_MODE=true
ALLOW_CLOUD_PROVIDERS=false
LLM_PROVIDER=local

VITE_GUARDIAN_API_KEY=
VITE_GUARDIAN_DEV_API_KEY=
