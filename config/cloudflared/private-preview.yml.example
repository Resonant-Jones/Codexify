# Named Cloudflare Tunnel configuration for the private preview.
# Copy outside the repository (or to an ignored local path) and replace only
# the placeholders. The credentials file is generated by cloudflared and must
# never be committed.
tunnel: <tunnel-uuid>
credentials-file: /Users/you/.cloudflared/<tunnel-uuid>.json

ingress:
  - hostname: preview.example.com
    service: http://127.0.0.1:8080
  - service: http_status:404
