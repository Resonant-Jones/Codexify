# .env.example — sample environment config for guardian-backend

# Google Gemini API Key for language model access
GENAI_API_KEY=sk-...your-gemini-key-here...

# Database file location (optional; default is guardian.db)
GUARDIAN_DB_PATH=guardian.db

# Notion API Key (if using Notion integrations)
NOTION_API_KEY=secret_notion_token_here

# Additional secrets (uncomment as needed)
# DISCORD_BOT_TOKEN=your_discord_bot_token
# OPENAI_API_KEY=sk-...openai-key-here...
# .env.example — sample environment config for guardian-backend
# Copy this file to .env and fill in your real secrets.
# Never commit your actual .env to git!

# === REQUIRED ===

# Google Gemini API Key for language model access
GENAI_API_KEY=sk-...your-gemini-key-here...

# === OPTIONAL ===

# Database file location (optional; default is guardian.db)
GUARDIAN_DB_PATH=guardian.db

# Notion API Key (if using Notion integrations)
NOTION_API_KEY=secret_notion_token_here

# Additional secrets (uncomment as needed)
# DISCORD_BOT_TOKEN=your_discord_bot_token
# OPENAI_API_KEY=sk-...openai-key-here...

# .env.example — sample environment config for guardian-backend
# Copy this file to `.env` and fill in your real secrets.
# Never commit your actual `.env` to git!

# === REQUIRED FOR LOCAL DEV / TESTS ===
# Use dummy placeholders in CI and for local tests.
GENAI_API_KEY=dummy
NOTION_API_KEY=dummy
ANTHROPIC_API_KEY=dummy

# Choose the LLM provider used by MemoryOS abstraction.
# Options: "openai" or "groq"
LLM_PROVIDER=groq
GROQ_API_KEY=dummy
# If using OpenAI locally, uncomment and set:
# OPENAI_API_KEY=sk-...openai-key-here...

# === OPTIONAL ===
# Database file location (default is guardian.db)
GUARDIAN_DB_PATH=guardian.db

# Notion API Key (if using Notion integrations) — set real value in your local `.env`
# NOTION_API_KEY=secret_notion_token_here

# Discord bot token (optional)
# DISCORD_BOT_TOKEN=your_discord_bot_token

# === Batch Runner (optional defaults) ===
# Configure which agent CLI and flags the batch runner uses.
# If unset, tools/run-batch.sh will auto-detect codex-cli or groq-code-cli on PATH.
# RUN_AGENT_CMD="codex-cli run"
# RUN_AGENT_PACK_FLAG="--prompt-pack"
# RUN_AGENT_MANIFEST_FLAG="--manifest"
# RUN_AGENT_ARTIFACTS_FLAG="--artifacts"
# RUN_AGENT_EXTRA="--concurrency 3"

# === Vector / Retrieval ===
GUARDIAN_INDEX_DIR=guardian_index
EMBEDDING_BACKEND=stub
EMBEDDING_DIM=128
# EMBEDDING_MODEL=all-MiniLM-L6-v2

# === ChatGPT Import Configuration ===
# Neo4j connection settings
NEO4J_URL=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASS=your-password-here

# Chroma vector database path
CHROMA_PATH=./chroma

# ChatGPT export file location
CHATGPT_EXPORT_FILE=./chatgpt_conversation.json

# OpenAI API key for embeddings (use the key above or set separately)
# OPENAI_API_KEY=sk-...openai-key-here...

# Embedding batch size for parallel processing (default: 20)
EMBED_BATCH_SIZE=20

# When 1, /events?tenant=foo will return only that tenant's events
ENABLE_SSE_FILTER=0

# === SECURITY: Rate Limiting ===
# Enable/disable rate limiting (default: enabled)
GUARDIAN_ENABLE_RATE_LIMITING=1

# Rate limits (comma-separated, supports: /second, /minute, /hour, /day)
# Examples:
#   - "100/minute" = max 100 requests per minute per IP
#   - "100/minute,1000/hour" = 100/min AND 1000/hour (both enforced)
#   - "10/second,500/minute,5000/hour" = multiple tiers
GUARDIAN_RATE_LIMITS=100/minute,1000/hour

# === SECURITY: HTTP Security Headers ===
# Enable/disable security headers middleware (default: enabled)
GUARDIAN_ENABLE_SECURITY_HEADERS=1

# Content-Security-Policy (CSP) directive
# Adjust based on your frontend requirements (default is restrictive)
# Note: 'unsafe-inline' is used for development; remove in production if possible
GUARDIAN_CSP_POLICY=default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:;
